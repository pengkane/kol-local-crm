{
  "manifest_version": 3,
  "name": "KOL Local CRM Collector",
  "version": "0.1.0",
  "description": "Quick-collect X accounts into the local KOL CRM desktop app.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://127.0.0.1:43112/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
